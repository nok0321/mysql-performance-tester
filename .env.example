# ─── セキュリティ設定 ──────────────────────────────────────────────────────
# Web UI の DB 接続パスワードを AES-256-GCM で暗号化するための秘密鍵。
# 32 文字以上のランダム文字列を設定してください。
# 未設定の場合はパスワードが平文で保存されます（非推奨）。
# 生成例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_random_secret_key_here

# ─── MySQL Database Configuration ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Optional: Connection Pool Settings
# DB_CONNECTION_LIMIT=10
# DB_CONNECT_TIMEOUT=10000
# DB_ACQUIRE_TIMEOUT=30000

# Optional: Test Configuration
# TEST_ITERATIONS=20
# PARALLEL_THREADS=10
# ENABLE_WARMUP=true
# WARMUP_PERCENTAGE=20

# Optional: Analysis Settings
# ENABLE_EXPLAIN_ANALYZE=true
# ENABLE_PERFORMANCE_SCHEMA=true
# ENABLE_OPTIMIZER_TRACE=true
# ENABLE_BUFFER_POOL_MONITORING=true

# Optional: Output Settings
# RESULT_DIRECTORY=./performance_results
# GENERATE_REPORT=true
